# 🌍 General Configuration
VITE_APP_NAME="Best Website"   # Change to your app name
VITE_ENV=production  # Set to 'production' in production environments

# 🖥️ Server Configuration
VITE_API_URL=https://tijara-backend-production.up.railway.app
VITE_PORT=3000        # Vite dev server port
VITE_OPEN_BROWSER=true  # Automatically open browser (true/false)

# 🗺️ Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# 🛢️ Database Configuration (Backend Use)


# 🔒 Security & Authentication
VITE_JWT_SECRET=my_super_secret_key  # Secret key for JWT auth (use in backend)
VITE_OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
VITE_OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
VITE_JWT_EXPIRY=7d
VITE_REFRESH_TOKEN_EXPIRY=30d

# 🛠️ Build Settings
VITE_BUILD_DIR=dist   # Change output directory if needed
VITE_DEBUG_MODE=true  # Set to false in production

# 📩 Email Configuration (Backend)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@example.com

# API Configuration
VITE_API_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_SOCIAL_LOGIN=false
VITE_ENABLE_2FA=false

# App Configuration
VITE_APP_DESCRIPTION="Your one-stop marketplace for vehicles and real estate"
VITE_SUPPORT_EMAIL=support@bestwebsite.com

# External Services
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=
